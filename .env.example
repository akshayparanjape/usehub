# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
FRONTEND_URL=http://localhost:3000
# Production/staging: explicit origins. In APP_ENV=development the API also allows any localhost port.
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://usehub:usehub@localhost:5432/usehub

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OAuth — Google ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ─────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Object Storage (S3 / Cloudflare R2) ────────────────────────────────────────
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=usehub
STORAGE_PUBLIC_URL=http://localhost:9000/usehub

# ── Sentry (optional) ──────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Dev login (only works when APP_ENV != production) ──────────────────────────
DEV_LOGIN_USERNAME=max
DEV_LOGIN_PASSWORD=mustermann

# ── Rate limits ────────────────────────────────────────────────────────────────
RATE_LIMIT_POST_PER_HOUR=100
RATE_LIMIT_GET_PER_HOUR=1000
